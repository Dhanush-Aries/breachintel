# BreachIntel environment variables (copy to .env and fill in real values)

# Shodan API key pool — comma-separated, used in round-robin with auto-failover.
# Even "0-query-credit" keys work for /shodan/host/{ip} and /shodan/host/count.
SHODAN_KEYS=key1,key2,key3

# Optional: a single Shodan key (added on top of SHODAN_KEYS by shodanpool._keys()).
SHODAN_API_KEY=

# Optional: keyed sources (auto-skipped if blank).
LEAKIX_API_KEY=
DEHASHED_API_KEY=
INTELX_API_KEY=
HIBP_API_KEY=

# Web GUI port (default 7474).
PORT=7474
